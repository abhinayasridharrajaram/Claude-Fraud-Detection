{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Read|Bash|Task|Glob|Grep|WebFetch",
        "hooks": [
          { "type": "command", "command": "powershell -ExecutionPolicy Bypass -File scripts/audit_hook.ps1" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "powershell -ExecutionPolicy Bypass -File scripts/audit_hook.ps1" }
        ]
      }
    ]
  }
}